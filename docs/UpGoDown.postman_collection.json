{
  "info": {
    "_postman_id": "upgodown-api-collection",
    "name": "UpGoDown API",
    "description": "Postman — только register и login (требование защиты).\n\nОстальное: Swagger http://localhost:5000/swagger",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth (Postman на защите)",
      "item": [
        {
          "name": "POST Register (новый пользователь)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"demo1\",\n  \"password\": \"123456\",\n  \"name\": \"Демо студент\",\n  \"role\": \"Student\"\n}"
            },
            "url": "{{baseUrl}}/register"
          }
        },
        {
          "name": "POST Login Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"student\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/login"
          }
        },
        {
          "name": "POST Login Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"teacher\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/login"
          }
        }
      ]
    }
  ]
}
