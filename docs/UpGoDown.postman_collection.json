    },
    {
      "name": "03 — Profile & Leaderboard",
      "item": [
        {
          "name": "GET My Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/myProfile"
          }
        },
        {
          "name": "GET Leaderboard Level 1",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/leaderboard/levels/1"
          }
